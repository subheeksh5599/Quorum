# Cleanverse API credentials (optional — falls back to in-memory demo data)
# Get your API ID and Key from https://cleanverse.com
CLEANVERSE_API_ID=
CLEANVERSE_API_KEY=

# Data provider: "memory" (default) or "cleanverse"
# When set to "cleanverse" + valid credentials, all transactions/votes/precedents
# are persisted to the Cleanverse UAT API instead of in-memory store.
DATA_PROVIDER=memory
